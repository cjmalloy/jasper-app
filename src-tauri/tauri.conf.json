{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jasper",
  "version": "1.1.12",
  "identifier": "com.github.cjmalloy.jasper-app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run build:ui",
    "beforeBuildCommand": "npm run build:ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Jasper",
        "url": "loading.html",
        "visible": false,
        "width": 1024,
        "height": 768
      },
      {
        "label": "loading",
        "title": "Jasper",
        "url": "loading.html",
        "visible": false,
        "width": 1024,
        "height": 768
      },
      {
        "label": "logs",
        "title": "Jasper Logs",
        "url": "logs.html",
        "visible": false,
        "width": 1024,
        "height": 768
      },
      {
        "label": "settings",
        "title": "Jasper Settings",
        "url": "settings.html",
        "visible": false,
        "width": 540,
        "height": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../docker-compose.yaml"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "entitlements": "../build/entitlements.mac.plist"
    }
  }
}
